Deployment



apiVersion: apps/v1
kind: Deployment
metadata:
  name: cognito-worker
  namespace: shared-dev-n
spec:
  replicas: 1
  selector:
    matchLabels:
      app: cognito-worker
  template:
    metadata:
      labels:
        app: cognito-worker
    spec:
      imagePullSecrets:
        - name: ucbosregistry
      containers:
        - name: cognito-worker
          image: <custom_image built using go code>
          ports:
            - containerPort: 2112
              name: metrics
          envFrom:
            - configMapRef:
                name: cognito-config
            - secretRef:
                name: cognito-secret
          resources:
            requests:
              cpu: "100m"
              memory: "128Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
          livenessProbe:
            httpGet:
              path: /metrics
              port: 2112
            initialDelaySeconds: 20
            periodSeconds: 30
          readinessProbe:
            httpGet:
              path: /metrics
              port: 2112
            initialDelaySeconds: 10
            periodSeconds: 20
      restartPolicy: Always
Service



apiVersion: v1
kind: Service
metadata:
  name: cognito-worker
  namespace: shared-dev-n
spec:
  selector:
    app: cognito-worker
  ports:
    - name: metrics
      port: 2112
      targetPort: 2112
ServiceMonitor



apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: cognito-worker
  namespace: monitoring
spec:
  selector:
    matchLabels:
      app: cognito-worker
  namespaceSelector:
    matchNames:
      - shared-dev-n
  endpoints:
    - port: metrics
      path: /metrics
      interval: 15s
